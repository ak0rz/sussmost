#!/usr/bin/env bash
set -euo pipefail

# sussmost - Remote Claude Tmux Session Manager
# Manage remote-controllable Claude Code sessions using tmux + worktrees
#
# Each tmux session maps to a git repository.
# Each window in that session runs Claude in an isolated worktree with remote-control.
# A persistent "hub" session acts as the command center, controllable from Claude app.

VERSION="0.1.0"
SUSSMOST_CONFIG_DIR="${SUSSMOST_CONFIG_DIR:-$HOME/.config/sussmost}"
SUSSMOST_SESSIONS_DIR="$SUSSMOST_CONFIG_DIR/sessions"
SUSSMOST_REPOS_FILE="$SUSSMOST_CONFIG_DIR/repos"
SUSSMOST_CLONE_DIR="${SUSSMOST_CLONE_DIR:-$HOME/.local/share/sussmost/repos}"
SUSSMOST_PREFIX="sussmost-"
SUSSMOST_HUB_SESSION="${SUSSMOST_PREFIX}hub"

# ---------------------------------------------------------------------------
# Utility functions
# ---------------------------------------------------------------------------

_die() {
    echo "sussmost: error: $*" >&2
    exit 1
}

_warn() {
    echo "sussmost: warning: $*" >&2
}

_info() {
    echo "sussmost: $*"
}

_ensure_dirs() {
    mkdir -p "$SUSSMOST_SESSIONS_DIR" "$SUSSMOST_CLONE_DIR"
    touch "$SUSSMOST_REPOS_FILE"
}

_tmux_name() {
    echo "${SUSSMOST_PREFIX}${1}"
}

_sanitize_name() {
    local name="$1"
    name="${name//./-}"
    name="${name//:/-}"
    name="${name// /-}"
    echo "$name"
}

_tmux_session_exists() {
    tmux has-session -t "$1" 2>/dev/null
}

_validate_git_repo() {
    local path="$1"
    [[ -d "$path" ]] || _die "path does not exist: $path"
    git -C "$path" rev-parse --git-dir >/dev/null 2>&1 || _die "not a git repository: $path"
}

_session_file() {
    echo "$SUSSMOST_SESSIONS_DIR/$1"
}

_session_exists() {
    local name="$1"
    local sf
    sf="$(_session_file "$name")"
    [[ -f "$sf" ]] && _tmux_session_exists "$(_tmux_name "$name")"
}

_read_session_repo() {
    local sf
    sf="$(_session_file "$1")"
    [[ -f "$sf" ]] || _die "no session metadata for: $1"
    grep '^repo=' "$sf" | head -1 | cut -d= -f2-
}

_list_session_windows() {
    local sf
    sf="$(_session_file "$1")"
    [[ -f "$sf" ]] || return 0
    grep '^window:' "$sf" | sort -t: -k2 -n
}

_window_exists_in_session() {
    local session="$1" worktree="$2" sf
    sf="$(_session_file "$session")"
    [[ -f "$sf" ]] && grep -q "^window:.*=${worktree}$" "$sf"
}

_next_window_index() {
    local sf max_idx
    sf="$(_session_file "$1")"
    if [[ ! -f "$sf" ]] || ! grep -q '^window:' "$sf"; then
        echo 0
        return
    fi
    max_idx=$(grep '^window:' "$sf" | sed 's/^window:\([0-9]*\)=.*/\1/' | sort -n | tail -1)
    echo $((max_idx + 1))
}

_add_window_meta() {
    local session="$1" idx="$2" worktree="$3"
    echo "window:${idx}=${worktree}" >> "$(_session_file "$session")"
}

_remove_window_meta() {
    local session="$1" worktree="$2" sf
    sf="$(_session_file "$session")"
    [[ -f "$sf" ]] || return 0
    sed -i "/^window:.*=${worktree}$/d" "$sf"
}

_detect_session() {
    # Auto-detect session name from SUSSMOST_SESSION env var
    if [[ -n "${SUSSMOST_SESSION:-}" ]]; then
        echo "$SUSSMOST_SESSION"
        return 0
    fi
    # If there's exactly one active session, use it
    local sessions=()
    if [[ -d "$SUSSMOST_SESSIONS_DIR" ]]; then
        for f in "$SUSSMOST_SESSIONS_DIR"/*; do
            [[ -f "$f" ]] || continue
            local name
            name="$(basename "$f")"
            [[ "$name" == "hub" ]] && continue
            if _tmux_session_exists "$(_tmux_name "$name")"; then
                sessions+=("$name")
            fi
        done
    fi
    if [[ ${#sessions[@]} -eq 1 ]]; then
        echo "${sessions[0]}"
        return 0
    fi
    return 1
}

_repo_path_for_name() {
    local name="$1"
    [[ -f "$SUSSMOST_REPOS_FILE" ]] || _die "no repos registered"
    local path
    path=$(grep "^${name}=" "$SUSSMOST_REPOS_FILE" | head -1 | cut -d= -f2-)
    [[ -n "$path" ]] || _die "repo not found: $name"
    echo "$path"
}

_repo_registered() {
    local name="$1"
    [[ -f "$SUSSMOST_REPOS_FILE" ]] && grep -q "^${name}=" "$SUSSMOST_REPOS_FILE"
}

# ---------------------------------------------------------------------------
# Hub commands
# ---------------------------------------------------------------------------

cmd_hub() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        start) _hub_start "$@" ;;
        stop)  _hub_stop "$@" ;;
        *)     _die "usage: sussmost hub {start|stop}" ;;
    esac
}

_hub_start() {
    _ensure_dirs

    if _tmux_session_exists "$SUSSMOST_HUB_SESSION"; then
        _info "hub already running"
        _info "attach with: sussmost hub attach  (or tmux attach -t $SUSSMOST_HUB_SESSION)"
        return 0
    fi

    tmux new-session -d -s "$SUSSMOST_HUB_SESSION" -n "hub"

    # Set up the hub window with sussmost context
    tmux send-keys -t "${SUSSMOST_HUB_SESSION}:hub" \
        "export SUSSMOST_SESSION=hub" Enter

    tmux send-keys -t "${SUSSMOST_HUB_SESSION}:hub" \
        "clear && echo '=== sussmost hub ===' && echo 'Starting Claude remote-control session...' && echo 'You can manage repos and sessions from Claude app.' && echo ''" Enter

    # Launch Claude with remote-control and system prompt about sussmost
    tmux send-keys -t "${SUSSMOST_HUB_SESSION}:hub" \
        "claude remote-control --name \"sussmost-hub\" --append-system-prompt \"You are the sussmost hub controller. You have the 'sussmost' CLI tool available to manage remote Claude sessions. Use it to: register repos (sussmost repo add/clone/list), start repo sessions (sussmost start), add worktree windows (sussmost add), check status (sussmost status), and stop sessions (sussmost stop). Always run sussmost commands to fulfill user requests about managing repos and Claude sessions.\"" Enter

    _info "hub started"
    _info "connect via Claude app to manage sessions remotely"
    _info "or attach directly: tmux attach -t $SUSSMOST_HUB_SESSION"
}

_hub_stop() {
    if _tmux_session_exists "$SUSSMOST_HUB_SESSION"; then
        tmux kill-session -t "$SUSSMOST_HUB_SESSION"
        _info "hub stopped"
    else
        _info "hub is not running"
    fi
}

# ---------------------------------------------------------------------------
# Repo commands
# ---------------------------------------------------------------------------

cmd_repo() {
    local subcmd="${1:-}"
    shift || true
    case "$subcmd" in
        add)    _repo_add "$@" ;;
        clone)  _repo_clone "$@" ;;
        list)   _repo_list "$@" ;;
        remove) _repo_remove "$@" ;;
        *)      _die "usage: sussmost repo {add|clone|list|remove}" ;;
    esac
}

_repo_add() {
    [[ $# -ge 2 ]] || _die "usage: sussmost repo add <name> <path>"
    _ensure_dirs

    local name path
    name="$(_sanitize_name "$1")"
    path="$(realpath "$2")"

    _validate_git_repo "$path"

    if _repo_registered "$name"; then
        _die "repo already registered: $name"
    fi

    echo "${name}=${path}" >> "$SUSSMOST_REPOS_FILE"
    _info "registered repo: $name -> $path"
}

_repo_clone() {
    [[ $# -ge 1 ]] || _die "usage: sussmost repo clone <url> [name]"
    _ensure_dirs

    local url="$1"
    local name="${2:-}"

    # Derive name from URL if not provided
    if [[ -z "$name" ]]; then
        name="$(basename "$url" .git)"
        name="$(_sanitize_name "$name")"
    else
        name="$(_sanitize_name "$name")"
    fi

    if _repo_registered "$name"; then
        _die "repo already registered: $name"
    fi

    local target="$SUSSMOST_CLONE_DIR/$name"
    if [[ -d "$target" ]]; then
        _die "directory already exists: $target"
    fi

    _info "cloning $url -> $target"
    git clone "$url" "$target"

    echo "${name}=${target}" >> "$SUSSMOST_REPOS_FILE"
    _info "registered repo: $name -> $target"
}

_repo_list() {
    _ensure_dirs
    if [[ ! -s "$SUSSMOST_REPOS_FILE" ]]; then
        _info "no repos registered"
        return 0
    fi
    echo "Registered repos:"
    while IFS='=' read -r name path; do
        [[ -z "$name" ]] && continue
        local status="ok"
        if [[ ! -d "$path" ]]; then
            status="MISSING"
        elif ! git -C "$path" rev-parse --git-dir >/dev/null 2>&1; then
            status="NOT GIT"
        fi
        printf "  %-20s %s [%s]\n" "$name" "$path" "$status"
    done < "$SUSSMOST_REPOS_FILE"
}

_repo_remove() {
    [[ $# -ge 1 ]] || _die "usage: sussmost repo remove <name>"
    _ensure_dirs

    local name="$1"
    if ! _repo_registered "$name"; then
        _die "repo not registered: $name"
    fi

    sed -i "/^${name}=/d" "$SUSSMOST_REPOS_FILE"
    _info "unregistered repo: $name (files not deleted)"
}

# ---------------------------------------------------------------------------
# Session commands
# ---------------------------------------------------------------------------

cmd_start() {
    [[ $# -ge 1 ]] || _die "usage: sussmost start <repo-name> [--worktree <name>]"
    _ensure_dirs

    local repo_name="$1"
    shift
    local initial_worktree=""

    # Parse optional --worktree flag
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --worktree|-w)
                [[ $# -ge 2 ]] || _die "--worktree requires a name"
                initial_worktree="$2"
                shift 2
                ;;
            *)
                _die "unknown option: $1"
                ;;
        esac
    done

    local repo_path session_name tmux_name
    repo_path="$(_repo_path_for_name "$repo_name")"
    session_name="$(_sanitize_name "$repo_name")"
    tmux_name="$(_tmux_name "$session_name")"

    _validate_git_repo "$repo_path"

    if _tmux_session_exists "$tmux_name"; then
        _die "session already running: $session_name (tmux: $tmux_name)"
    fi

    # Create tmux session with control window
    tmux new-session -d -s "$tmux_name" -n "control" -c "$repo_path"

    # Set up control window environment
    tmux send-keys -t "${tmux_name}:control" \
        "export SUSSMOST_SESSION='${session_name}'" Enter

    tmux send-keys -t "${tmux_name}:control" \
        "clear && echo '=== sussmost: ${session_name} ===' && echo 'Repo: ${repo_path}' && echo '' && echo 'Commands:' && echo '  sussmost add <worktree>     - add Claude worktree window' && echo '  sussmost status             - show session status' && echo '  sussmost stop <worktree>    - stop a worktree window' && echo '  sussmost stop               - stop entire session' && echo ''" Enter

    # Write session metadata
    local sf
    sf="$(_session_file "$session_name")"
    echo "repo=${repo_path}" > "$sf"

    _info "session started: $session_name"
    _info "repo: $repo_path"
    _info "attach with: sussmost attach $session_name"

    # Add initial worktree if requested
    if [[ -n "$initial_worktree" ]]; then
        cmd_add "$session_name" "$initial_worktree"
    fi
}

cmd_add() {
    local session_name="" worktree_name=""

    case $# in
        1)
            # Auto-detect session
            worktree_name="$1"
            session_name="$(_detect_session)" || _die "cannot auto-detect session; specify: sussmost add <session> <worktree>"
            ;;
        2)
            session_name="$1"
            worktree_name="$2"
            ;;
        *)
            _die "usage: sussmost add [session] <worktree-name>"
            ;;
    esac

    _ensure_dirs
    session_name="$(_sanitize_name "$session_name")"
    worktree_name="$(_sanitize_name "$worktree_name")"

    local tmux_name
    tmux_name="$(_tmux_name "$session_name")"

    if ! _tmux_session_exists "$tmux_name"; then
        _die "session not running: $session_name"
    fi

    local sf
    sf="$(_session_file "$session_name")"
    if [[ ! -f "$sf" ]]; then
        _die "no session metadata for: $session_name"
    fi

    if _window_exists_in_session "$session_name" "$worktree_name"; then
        _die "worktree already exists in session: $worktree_name"
    fi

    local repo_path idx
    repo_path="$(_read_session_repo "$session_name")"
    idx="$(_next_window_index "$session_name")"

    # Create new tmux window
    tmux new-window -t "$tmux_name" -n "$worktree_name" -c "$repo_path"

    # Launch Claude in worktree with remote-control
    tmux send-keys -t "${tmux_name}:${worktree_name}" \
        "claude -w '${worktree_name}' remote-control --name '${session_name}/${worktree_name}'" Enter

    _add_window_meta "$session_name" "$idx" "$worktree_name"
    _info "added worktree window: ${session_name}/${worktree_name}"
}

cmd_list() {
    _ensure_dirs

    local found=false

    # Check hub
    if _tmux_session_exists "$SUSSMOST_HUB_SESSION"; then
        echo "Hub: $SUSSMOST_HUB_SESSION (active)"
        found=true
    fi

    # Check repo sessions
    for sf in "$SUSSMOST_SESSIONS_DIR"/*; do
        [[ -f "$sf" ]] || continue
        local name
        name="$(basename "$sf")"
        local tmux_name
        tmux_name="$(_tmux_name "$name")"
        local status="active"

        if ! _tmux_session_exists "$tmux_name"; then
            status="dead"
        fi

        local repo_path=""
        repo_path=$(grep '^repo=' "$sf" 2>/dev/null | head -1 | cut -d= -f2- || true)

        echo ""
        echo "Session: $name ($status)"
        [[ -n "$repo_path" ]] && echo "  Repo: $repo_path"
        echo "  Windows:"

        local has_windows=false
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local idx wt
            idx=$(echo "$line" | sed 's/^window:\([0-9]*\)=.*/\1/')
            wt=$(echo "$line" | sed 's/^window:[0-9]*=//')
            printf "    [%s] %s\n" "$idx" "$wt"
            has_windows=true
        done < <(_list_session_windows "$name")

        if [[ "$has_windows" == "false" ]]; then
            echo "    (no worktree windows)"
        fi

        found=true
    done

    if [[ "$found" == "false" ]]; then
        _info "no active sessions"
    fi
}

cmd_attach() {
    [[ $# -ge 1 ]] || _die "usage: sussmost attach <session-name>"

    local session_name tmux_name
    session_name="$(_sanitize_name "$1")"
    tmux_name="$(_tmux_name "$session_name")"

    if ! _tmux_session_exists "$tmux_name"; then
        _die "session not running: $session_name"
    fi

    if [[ -n "${TMUX:-}" ]]; then
        tmux switch-client -t "$tmux_name"
    else
        tmux attach-session -t "$tmux_name"
    fi
}

cmd_stop() {
    local session_name="" window_name=""

    case $# in
        0)
            # Auto-detect session, stop entire session
            session_name="$(_detect_session)" || _die "usage: sussmost stop [session] [window]"
            ;;
        1)
            # Could be session name, or could be window name with auto-detect
            local arg="$1"
            if _session_exists "$arg" || [[ -f "$(_session_file "$arg")" ]]; then
                session_name="$arg"
            else
                # Try auto-detect session, treat arg as window
                session_name="$(_detect_session 2>/dev/null)" || _die "session not found: $arg"
                window_name="$arg"
            fi
            ;;
        2)
            session_name="$1"
            window_name="$2"
            ;;
        *)
            _die "usage: sussmost stop [session] [window]"
            ;;
    esac

    session_name="$(_sanitize_name "$session_name")"
    local tmux_name
    tmux_name="$(_tmux_name "$session_name")"

    if [[ -n "$window_name" ]]; then
        # Stop specific window
        window_name="$(_sanitize_name "$window_name")"

        if _tmux_session_exists "$tmux_name"; then
            if tmux list-windows -t "$tmux_name" -F '#{window_name}' 2>/dev/null | grep -q "^${window_name}$"; then
                tmux kill-window -t "${tmux_name}:${window_name}"
            fi
        fi

        _remove_window_meta "$session_name" "$window_name"
        _info "stopped worktree: ${session_name}/${window_name}"

        # If no windows remain, clean up
        local sf
        sf="$(_session_file "$session_name")"
        if [[ -f "$sf" ]] && ! grep -q '^window:' "$sf"; then
            _info "no worktree windows remain in session"
        fi
    else
        # Stop entire session
        if _tmux_session_exists "$tmux_name"; then
            tmux kill-session -t "$tmux_name"
        fi

        local sf
        sf="$(_session_file "$session_name")"
        [[ -f "$sf" ]] && rm -f "$sf"

        _info "stopped session: $session_name"
    fi
}

cmd_status() {
    _ensure_dirs

    local found=false

    # Hub status
    echo "=== sussmost status ==="
    echo ""
    if _tmux_session_exists "$SUSSMOST_HUB_SESSION"; then
        local hub_pid
        hub_pid=$(tmux list-panes -t "${SUSSMOST_HUB_SESSION}:hub" -F '#{pane_pid}' 2>/dev/null | head -1 || echo "?")
        echo "Hub: ACTIVE (pid: $hub_pid)"
    else
        echo "Hub: STOPPED"
    fi

    # Repo sessions
    for sf in "$SUSSMOST_SESSIONS_DIR"/*; do
        [[ -f "$sf" ]] || continue
        local name
        name="$(basename "$sf")"
        local tmux_name
        tmux_name="$(_tmux_name "$name")"

        echo ""
        local repo_path=""
        repo_path=$(grep '^repo=' "$sf" 2>/dev/null | head -1 | cut -d= -f2- || true)

        if _tmux_session_exists "$tmux_name"; then
            echo "Session: $name (ACTIVE)"
        else
            echo "Session: $name (STALE - tmux session dead)"
            echo "  Repo: ${repo_path:-unknown}"
            echo "  Run 'sussmost stop $name' to clean up metadata"
            found=true
            continue
        fi

        [[ -n "$repo_path" ]] && echo "  Repo: $repo_path"
        echo "  Windows:"

        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            local idx wt
            idx=$(echo "$line" | sed 's/^window:\([0-9]*\)=.*/\1/')
            wt=$(echo "$line" | sed 's/^window:[0-9]*=//')

            # Get live process info
            local proc_info="?"
            if tmux list-windows -t "$tmux_name" -F '#{window_name}' 2>/dev/null | grep -q "^${wt}$"; then
                local pane_cmd pane_pid
                pane_cmd=$(tmux list-panes -t "${tmux_name}:${wt}" -F '#{pane_current_command}' 2>/dev/null | head -1 || echo "?")
                pane_pid=$(tmux list-panes -t "${tmux_name}:${wt}" -F '#{pane_pid}' 2>/dev/null | head -1 || echo "?")
                proc_info="${pane_cmd} (pid: ${pane_pid})"
            else
                proc_info="window not found"
            fi

            printf "    [%s] %-20s - %s\n" "$idx" "$wt" "$proc_info"
        done < <(_list_session_windows "$name")

        found=true
    done

    if [[ "$found" == "false" ]]; then
        echo ""
        echo "No repo sessions active."
    fi
}

cmd_help() {
    cat <<'HELP'
sussmost - Remote Claude Tmux Session Manager

Manage remote-controllable Claude Code sessions using tmux and git worktrees.
Each tmux session maps to a repository. Each window runs Claude in an isolated
worktree with remote-control, accessible from Claude app or mobile.

USAGE:
  sussmost <command> [arguments]

HUB COMMANDS:
  hub start                  Start the hub (Claude remote-control command center)
  hub stop                   Stop the hub session

REPO COMMANDS:
  repo add <name> <path>     Register an existing git repo
  repo clone <url> [name]    Clone a repo and register it
  repo list                  List all registered repos
  repo remove <name>         Unregister a repo (files kept)

SESSION COMMANDS:
  start <repo> [-w <name>]   Start tmux session for a registered repo
  add [session] <worktree>   Add a Claude worktree window to a session
  list                       List all sessions and windows
  attach <session>           Attach to a session's tmux
  stop [session] [window]    Stop a worktree window or entire session
  status                     Show live status of all sessions

OTHER:
  help                       Show this help
  version                    Show version

EXAMPLES:
  # First-time setup
  sussmost hub start

  # Register and start working on a repo
  sussmost repo add myapi /home/user/projects/my-api
  sussmost start myapi
  sussmost add myapi auth-feature
  sussmost add myapi billing-bugfix

  # Check what's running
  sussmost status

  # Inside a sussmost tmux session (auto-detects session)
  sussmost add new-feature
  sussmost stop old-feature

  # Clone and immediately start
  sussmost repo clone https://github.com/acme/tools.git
  sussmost start tools -w main

ENVIRONMENT:
  SUSSMOST_SESSION           Auto-set inside tmux sessions for context detection
  SUSSMOST_CONFIG_DIR        Config directory (default: ~/.config/sussmost)
  SUSSMOST_CLONE_DIR         Clone target (default: ~/.local/share/sussmost/repos)

HELP
}

cmd_version() {
    echo "sussmost $VERSION"
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------

main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        hub)     cmd_hub "$@" ;;
        repo)    cmd_repo "$@" ;;
        start)   cmd_start "$@" ;;
        add)     cmd_add "$@" ;;
        list)    cmd_list "$@" ;;
        attach)  cmd_attach "$@" ;;
        stop)    cmd_stop "$@" ;;
        status)  cmd_status "$@" ;;
        help|-h|--help)    cmd_help ;;
        version|--version) cmd_version ;;
        "")      cmd_help ;;
        *)       _die "unknown command: $cmd. Run 'sussmost help' for usage." ;;
    esac
}

main "$@"
